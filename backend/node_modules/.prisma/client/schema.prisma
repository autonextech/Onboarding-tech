generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String // 'ADMIN', 'CANDIDATE', or 'MENTOR'
  department   String?
  isActive     Boolean  @default(true)
  mentorId     String?
  mentor       User?    @relation("MentorToCandidate", fields: [mentorId], references: [id])
  mentees      User[]   @relation("MentorToCandidate")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  progress     CandidateProgress[]
  quizAttempts QuizAttempt[]

  @@index([mentorId])
}

model Module {
  id            String    @id @default(uuid())
  title         String
  description   String
  status        String // 'DRAFT' or 'PUBLISHED'
  assessmentUrl String? // External assessment portal link
  sections      Section[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  candidateProgress CandidateProgress[]
}

model Section {
  id            String         @id @default(uuid())
  moduleId      String
  module        Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title         String
  description   String
  videoUrl      String?
  videoDuration String?
  order         Int            @default(0)
  documents     Document[]
  questions     QuizQuestion[]

  candidateProgress CandidateProgress[]
  quizAttempts      QuizAttempt[]

  @@index([moduleId])
}

model Document {
  id        String  @id @default(uuid())
  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  title     String
  type      String
  url       String
}

model QuizQuestion {
  id                 String  @id @default(uuid())
  sectionId          String
  section            Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  question           String
  options            String // Stored as JSON string
  correctOptionIndex Int

  attempts QuizAttempt[]
}

model CandidateProgress {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  sectionId   String
  section     Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@unique([userId, sectionId])
  @@index([userId])
  @@index([moduleId])
}

model QuizAttempt {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId  String
  question    QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  sectionId   String
  section     Section      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  chosenIndex Int
  isCorrect   Boolean
  attemptedAt DateTime     @default(now())

  @@unique([userId, questionId])
  @@index([userId])
  @@index([sectionId])
}

model TeamMember {
  id         String   @id @default(uuid())
  name       String
  role       String
  department String
  email      String?
  linkedin   String?
  slack      String?
  createdAt  DateTime @default(now())
}
